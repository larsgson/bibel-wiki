---
import BaseLayout from "../../../layouts/BaseLayout.astro"
import NavigationGridIsland from "../../../components/NavigationGridIsland"
import { loadAllTemplates, loadLocaleData, loadAllLocaleData, extractStoryTestaments, getTemplateThemeCSS } from "../../../lib/template-utils"
import { POPULAR_LANGUAGES } from "../../../lib/popular-languages"

export function getStaticPaths() {
  const templates = loadAllTemplates()
  const paths: any[] = []

  for (const [name, structure] of Object.entries(templates)) {
    const engLocale = loadLocaleData(name, "eng")
    const allLocales = loadAllLocaleData(name)
    const storyTestaments = extractStoryTestaments(name)

    for (const lang of POPULAR_LANGUAGES) {
      paths.push({
        params: { lang, template: name },
        props: {
          templateName: name,
          structure,
          engLocale,
          allLocales,
          storyTestaments,
        },
      })
    }
  }

  return paths
}

const { templateName, structure, engLocale, allLocales, storyTestaments } = Astro.props
const pageTitle = engLocale?.bookTitle || templateName
---

<BaseLayout title={`${pageTitle} — Bibel Wiki`} layoutTheme={structure.layoutTheme} themeCSS={getTemplateThemeCSS(templateName)}>
  <div class="max-w-4xl mx-auto p-4">
    <NavigationGridIsland
      client:load
      templateName={templateName}
      structure={structure}
      engLocale={engLocale}
      allLocales={allLocales}
      storyTestaments={storyTestaments}
      imageConfig={structure.imageConfig}
    />
  </div>
</BaseLayout>
