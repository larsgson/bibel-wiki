---
import BaseLayout from "../../../layouts/BaseLayout.astro"
import StoryReaderIsland from "../../../components/StoryReaderIsland"
import NavigationGridIsland from "../../../components/NavigationGridIsland"
import {
  loadAllTemplates,
  loadLocaleData,
  buildImageIndex,
  loadMarkdownContent,
  loadAllLocaleData,
  findMissingStoryIds,
  extractStoryTestaments,
  getTemplateThemeCSS,
} from "../../../lib/template-utils"
import { POPULAR_LANGUAGES } from "../../../lib/popular-languages"

export function getStaticPaths() {
  const templates = loadAllTemplates()
  const paths: any[] = []

  for (const [name, structure] of Object.entries(templates)) {
    const engLocale = loadLocaleData(name, "eng")
    const imageIndex = buildImageIndex(name)
    const allLocales = loadAllLocaleData(name)
    const missingStoryIds = findMissingStoryIds(name)
    const storyTestaments = extractStoryTestaments(name)

    for (const cat of structure.categories) {
      // Category-level page (e.g. /swe/John/01/)
      for (const lang of POPULAR_LANGUAGES) {
        paths.push({
          params: { lang, template: name, path: cat.id },
          props: {
            pageType: "category" as const,
            templateName: name,
            structure,
            categoryId: cat.id,
            engLocale,
            allLocales,
            missingStoryIds,
            storyTestaments,
            layoutTheme: structure.layoutTheme,
          },
        })
      }

      // Story-level pages (e.g. /swe/John/01/03)
      for (const story of cat.stories) {
        const markdownContent = loadMarkdownContent(name, cat.id, story.id) || ""

        for (const lang of POPULAR_LANGUAGES) {
          paths.push({
            params: {
              lang,
              template: name,
              path: `${cat.id}/${story.id}`,
            },
            props: {
              pageType: "story" as const,
              templateName: name,
              categoryId: cat.id,
              storyId: story.id,
              engLocale,
              imageIndex,
              markdownContent,
              allLocales,
              layoutTheme: structure.layoutTheme,
              imageConfig: structure.imageConfig,
            },
          })
        }
      }
    }
  }

  return paths
}

const props = Astro.props
const pageTitle = props.engLocale?.bookTitle || props.templateName
---

<BaseLayout title={`${pageTitle} — Bibel Wiki`} layoutTheme={props.layoutTheme} themeCSS={getTemplateThemeCSS(props.templateName)}>
  {props.pageType === "category" ? (
    <div class="max-w-4xl mx-auto p-4">
      <NavigationGridIsland
        client:load
        templateName={props.templateName}
        structure={props.structure}
        engLocale={props.engLocale}
        allLocales={props.allLocales}
        defaultCategoryId={props.categoryId}
        missingStoryIds={props.missingStoryIds}
        storyTestaments={props.storyTestaments}
        imageConfig={props.structure.imageConfig}
      />
    </div>
  ) : (
    <div class="max-w-3xl mx-auto p-4">
      <StoryReaderIsland
        client:only="react"
        templateName={props.templateName}
        categoryId={props.categoryId}
        storyId={props.storyId}
        engLocale={props.engLocale}
        imageIndex={props.imageIndex}
        markdownContent={props.markdownContent}
        allLocales={props.allLocales}
        imageConfig={props.imageConfig}
      />
    </div>
  )}
</BaseLayout>
